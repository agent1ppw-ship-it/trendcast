{
  "name": "trendcast-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "assets:generate": "node ./scripts/generate-brand-assets.mjs",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:ios:production": "npx eas-cli build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~52.0.0",
    "expo-apple-authentication": "~7.1.3",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.3",
    "expo-status-bar": "~2.0.0",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "0.76.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "^18.3.7",
    "eas-cli": "^18.4.0",
    "typescript": "^5.6.3"
  }
}
