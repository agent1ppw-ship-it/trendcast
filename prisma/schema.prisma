generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id               String   @id @default(uuid())
  name             String
  tier             String   @default("INTRO") // INTRO, PRO, ULTIMATE, ENTERPRISE
  industry         String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  credits          Int      @default(50)
  extracts         Int      @default(10)
  createdAt        DateTime @default(now())
  
  users            User[]
  leads            Lead[]
  jobs             Job[]
  aiSettings       AiConfig?
  mailTemplates    MailTemplate[]
  mailCampaigns    MailCampaign[]
  mailOrders       MailOrder[]
}

model User {
  id             String    @id @default(uuid())
  orgId          String?   // Make orgId optional since NextAuth creates the user first
  organization   Organization? @relation(fields: [orgId], references: [id])
  name           String?
  email          String?   @unique
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  role           String    @default("USER") // ADMIN, USER
  createdAt      DateTime  @default(now())
  
  accounts       Account[]
  sessions       Session[]
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id             String   @id @default(uuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  name           String
  phone          String?
  address        String?
  source         String   @default("SCRAPER") // ORGANIC, SCRAPER, MANUAL
  leadScore      Int      @default(0)
  status         String   @default("NEW") // NEW, CONTACTED, QUOTED, WON, LOST
  isRevealed     Boolean  @default(false)
  createdAt      DateTime @default(now())
  mailOrders     MailOrder[]
  addressVerifications AddressVerification[]
}

model AiConfig {
  id             String   @id @default(uuid())
  orgId          String   @unique
  organization   Organization @relation(fields: [orgId], references: [id])
  systemPrompt   String   @db.Text
  autoReplySMS   Boolean  @default(false)
  autoSchedule   Boolean  @default(false)
  twilioNumber   String?
}

model Job {
  id             String   @id @default(uuid())
  orgId          String
  organization   Organization @relation(fields: [orgId], references: [id])
  title          String
  status         String   @default("PENDING") // PENDING, SCHEDULED, COMPLETED, INVOICED
  scheduledFor   DateTime?
  createdAt      DateTime @default(now())
}

model MailTemplate {
  id             String        @id @default(uuid())
  orgId          String
  organization   Organization  @relation(fields: [orgId], references: [id])
  name           String
  type           String        @default("POSTCARD") // POSTCARD, LETTER
  size           String        @default("4X6") // 4X6, 6X9, 8_5X11
  frontHeadline  String
  frontBody      String        @db.Text
  backHeadline   String?
  backBody       String        @db.Text
  ctaText        String?
  accentColor    String        @default("#2563EB")
  imageUrl       String?
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  campaigns      MailCampaign[]
}

model MailCampaign {
  id                  String        @id @default(uuid())
  orgId               String
  organization        Organization  @relation(fields: [orgId], references: [id])
  templateId          String
  template            MailTemplate  @relation(fields: [templateId], references: [id])
  name                String
  targetType          String        @default("CUSTOM") // ALL_LEADS, CUSTOM, SEGMENT
  targetLeadIds       Json
  status              String        @default("DRAFT") // DRAFT, SCHEDULED, READY_TO_SEND, SENDING, COMPLETED, CANCELLED, FAILED
  mailType            String        @default("POSTCARD")
  mailSize            String        @default("4X6")
  postageClass        String        @default("MARKETING")
  scheduledAt         DateTime?
  sentCount           Int           @default(0)
  failedCount         Int           @default(0)
  costCents           Int           @default(0)
  stripeCheckoutId    String?
  stripePaymentStatus String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  orders              MailOrder[]
}

model MailOrder {
  id                String              @id @default(uuid())
  orgId             String
  organization      Organization        @relation(fields: [orgId], references: [id])
  campaignId        String
  campaign          MailCampaign        @relation(fields: [campaignId], references: [id])
  leadId            String
  lead              Lead                @relation(fields: [leadId], references: [id])
  lobObjectId       String?
  lobTrackingId     String?
  recipientName     String
  recipientAddress  String
  recipientCity     String?
  recipientState    String?
  recipientZip      String?
  status            String              @default("PENDING") // PENDING, VERIFIED, QUEUED, PRINTING, MAILED, DELIVERED, FAILED, SKIPPED
  sentAt            DateTime?
  deliveredAt       DateTime?
  costCents         Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  trackingEvents    MailTrackingEvent[]
}

model MailTrackingEvent {
  id          String    @id @default(uuid())
  orderId     String
  order       MailOrder @relation(fields: [orderId], references: [id])
  eventType   String
  eventData   Json?
  receivedAt  DateTime  @default(now())
}

model AddressVerification {
  id                  String   @id @default(uuid())
  leadId              String
  lead                Lead     @relation(fields: [leadId], references: [id])
  originalAddress     String
  standardizedAddress String?
  deliverable         Boolean  @default(false)
  lobId               String?
  metadata            Json?
  createdAt           DateTime @default(now())
}
